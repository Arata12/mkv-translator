# Select one: gemini, ollama-local, ollama-cloud
LLM_PROVIDER=gemini
# Default Gemini model: models/gemma-4-26b-a4b-it
LLM_MODEL=
# Default Gemini audio fallback: models/gemini-3.1-flash-lite-preview
LLM_AUDIO_MODEL=
LLM_BASE_URL=

# Gemini
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_API_KEY=
